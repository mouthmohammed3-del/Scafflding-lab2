<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ScaffoldingLab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
        }

        .wrapper {
            display: flex;
        }

        .sidebar {
            width: 70px; /* Sidebar مصغر بشكل افتراضي */
            height: 100vh;
            background: #343a40;
            color: white;
            position: fixed;
            transition: width 0.3s;
            overflow: hidden;
        }

            .sidebar:hover {
                width: 230px; /* يكبر عند المرور */
            }

            .sidebar h4 {
                padding: 20px;
                text-align: center;
                border-bottom: 1px solid #495057;
                opacity: 0;
                transition: opacity 0.3s;
            }

            .sidebar:hover h4 {
                opacity: 1;
            }

            .sidebar a {
                display: block;
                padding: 12px 20px;
                color: #ced4da;
                text-decoration: none;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

                .sidebar a:hover {
                    background: #495057;
                    color: white;
                }

        .content {
            margin-left: 70px;
            padding: 25px;
            width: 100%;
            transition: margin-left 0.3s;
            background: #f8f9fa;
            min-height: 100vh;
        }

        .sidebar:hover ~ .content {
            margin-left: 230px; /* المحتوى يتحرك تلقائياً عند تكبير الـ Sidebar */
        }

        footer {
            text-align: center;
            padding: 10px;
            color: gray;
        }
    </style>
</head>

<body>
    <div class="wrapper">

        <div class="sidebar">
            <h4>ScaffoldingLab</h4>
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <a asp-controller="Student" asp-action="Index">Students</a>
            <a asp-controller="Subject" asp-action="Index">Subjects</a>
            <a asp-controller="Teacher" asp-action="Index">Teachers</a>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            <a asp-controller="Account" asp-action="Logout">Logout</a>
            <a asp-controller="Roles" asp-action="Index">Roles</a> 
            <a asp-controller="Account" asp-action="Index">Users</a>
        </div>

        <div class="content">
            <main role="main">
                @RenderBody()
            </main>
            <footer>
                © 2026 - ScaffoldingLab System
            </footer>
        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>