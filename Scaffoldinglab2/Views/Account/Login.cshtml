                asp-items="@(new SelectList(ViewBag.Teachers, "Id", "Name"))"
                class="form-control">


                <option value="">-- No Teacher --</option>
                </select>
                <span asp-validation-for="TeacherId" class="text-danger"></span>
                </div>*@

